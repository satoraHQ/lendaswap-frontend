# Debug mode - enables step-by-step UI navigation without backend
VITE_DEBUG_MODE=true

# Lendaswap API URL
VITE_LENDASWAP_API_URL=http://localhost:3333

# Esplora API URL for on-chain Bitcoin operations
VITE_ESPLORA_URL=https://mempool.space/api

# PostHog Analytics
# Get your API key from https://app.posthog.com/project/settings
VITE_POSTHOG_API_KEY=your-posthog-api-key-here
VITE_POSTHOG_HOST=https://eu.i.posthog.com
# Set to "true" to disable PostHog entirely (or run localStorage.setItem("posthog_disabled", "true") in the browser console)
VITE_POSTHOG_DISABLED=false

# Chatwoot Live Chat
# Get your website token from https://app.chatwoot.com → Settings → Inboxes → your inbox
VITE_CHATWOOT_WEBSITE_TOKEN=YOUR_CHATWOOT_WEBSITE_TOKEN

# Referral code used by the frontend to attribute swaps to itself
VITE_REF_CODE=

# Value to set on every request from the frontend to the backend to identify the request source (Optional)
VITE_REQUEST_SOURCE=satora-web